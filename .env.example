# MAARS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# INFRASTRUCTURE
# ============================================================================

# Database (Local Dev uses PostgreSQL, Production uses AstraDB)
DATABASE_URL=postgresql://maars:password@localhost:5432/maars
ASTRA_DB_TOKEN=
ASTRA_DB_ENDPOINT=
ASTRA_DB_KEYSPACE=maars

# Event Streaming (Local Dev uses Redpanda, Production uses Astra Streaming)
KAFKA_BROKERS=localhost:19092
ASTRA_STREAMING_TOKEN=

# Cache & Sessions
REDIS_URL=redis://localhost:6379

# Object Storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=maars-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Secrets Management
VAULT_URL=http://localhost:8200
VAULT_TOKEN=dev-root-token

# ============================================================================
# SECURITY & IDENTITY
# ============================================================================

# JWT Configuration
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_EXPIRY_SECONDS=3600

# DID Configuration (Phase 3+)
DID_METHOD=did:key
ED25519_PRIVATE_KEY=

# Agent Name Service (Phase 3+)
ANS_REGISTRY_URL=https://ans.maars.ai
A2A_ENDPOINT=https://a2a.maars.ai

# ============================================================================
# LLM PROVIDERS
# ============================================================================

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google
GOOGLE_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Default Models
DEFAULT_NANO_MODEL=llama-3-8b-instruct
DEFAULT_MID_MODEL=llama-3-70b-instruct
DEFAULT_FRONTIER_MODEL=gpt-4.1

# ============================================================================
# OBSERVABILITY
# ============================================================================

# Arize Phoenix
ARIZE_SPACE_ID=
ARIZE_API_KEY=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=maars

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================

# Web Search
SERPER_API_KEY=
BRAVE_API_KEY=

# Communication
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# CRM
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_API_KEY=

# Payments
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Development Tools
GITHUB_TOKEN=
JIRA_API_TOKEN=

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# vessel-gateway
GATEWAY_PORT=8000
PROMPT_INJECTION_THRESHOLD=0.85
RATE_LIMIT_DEFAULT=100

# vessel-orchestrator
ORCHESTRATOR_PORT=8081
SIMULATION_CONFIDENCE_THRESHOLD=0.80
MAX_TASK_DEPTH=5

# vessel-llm-router
LLM_ROUTER_PORT=8082
SEMANTIC_CACHE_THRESHOLD=0.95

# vessel-identity
IDENTITY_PORT=8083
JIT_TOKEN_TTL_SECONDS=3600
CAEP_CHECK_INTERVAL_MS=5000

# vessel-memory
MEMORY_PORT=8084
EMBEDDING_MODEL=text-embedding-3-large
MEMORY_TTL_EPISODIC_DAYS=90
MEMORY_TTL_SEMANTIC_DAYS=365

# vessel-sandbox
SANDBOX_PORT=8085
WASM_MAX_MEMORY_MB=512
WASM_MAX_CPU_CORES=2
WASM_MAX_EXECUTION_SECONDS=300

# vessel-swarm
SWARM_PORT=8086

# vessel-observability
OBSERVABILITY_PORT=8087
GUARDRAIL_MODEL=gpt-4.1-mini
GUARDRAIL_THRESHOLD=0.75

# vessel-simulation
SIMULATION_PORT=8088

# vessel-research
RESEARCH_PORT=8089

# vessel-economics
ECONOMICS_PORT=8090
BLOCKCHAIN_PROVIDER=https://mainnet.base.org
ESCROW_PRIVATE_KEY=
ERC4337_FACTORY_ADDRESS=
X402_ENABLED=false
DEFAULT_LIABILITY_CAP_USD=1000

# vessel-integrations
INTEGRATIONS_PORT=8091
MCP_SERVER_NAME=maars-integrations
MCP_SERVER_VERSION=1.0.0

# vessel-interface
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

ENABLE_PHASE_3_FEATURES=false
ENABLE_PHASE_4_FEATURES=false
ENABLE_SIMULATION=true
ENABLE_SELF_IMPROVEMENT=true
ENABLE_WEBHOOKS=true

# ============================================================================
# DEVELOPMENT
# ============================================================================

NODE_ENV=development
LOG_LEVEL=debug
ENABLE_DEBUG_LOGGING=true